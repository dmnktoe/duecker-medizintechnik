{
  "name": "duecker-medizintechnik",
  "version": "1.1.0",
  "private": true,
  "author": "Domenik Toefflinger",
  "description": "Website for Duecker Medizintechnik",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prepare": "husky install",
    "clean": "rm -rf .next/ coverage/",
    "clean:nm": "pnpm clean && rm -rf node_modules/"
  },
  "dependencies": {
    "@datadog/browser-rum": "^5.24.0",
    "@hookform/resolvers": "^3.9.0",
    "@next/bundle-analyzer": "^14.2.7",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@sentry/nextjs": "^8",
    "@vercel/speed-insights": "^1.0.12",
    "axios": "^1.7.5",
    "clsx": "^2.1.1",
    "express-handlebars": "^7.1.3",
    "flagsmith": "^4.0.3",
    "framer-motion": "^11.3.31",
    "i18next": "^23.14.0",
    "marked": "^12.0.2",
    "next": "^14.2.7",
    "next-i18next": "^15.3.1",
    "nextjs-progressbar": "^0.0.16",
    "nodemailer": "^6.9.14",
    "nodemailer-express-handlebars": "^7.0.0",
    "qs": "^6.13.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.3.0",
    "react-scrollspy-navigation": "^2.0.6",
    "react-share": "^5.1.0",
    "swiper": "^11.1.11",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.8",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^15.0.7",
    "@types/gtag.js": "^0.0.20",
    "@types/jest": "^29.5.12",
    "@types/nodemailer": "^6.4.15",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/qs": "^6.9.15",
    "@types/react": "^18.3.4",
    "@types/react-google-recaptcha": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "axios-mock-adapter": "^1.22.0",
    "cobe": "^0.6.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.7",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.3",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.9",
    "next-router-mock": "^0.9.13",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "react-spring": "^9.7.4",
    "tailwindcss": "^3.4.10",
    "tailwindcss-debug-screens": "^2.2.1",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
  }
}
