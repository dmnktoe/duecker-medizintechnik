{
  "name": "duecker-medizintechnik",
  "version": "1.1.0",
  "private": true,
  "author": "Domenik Toefflinger",
  "description": "Website for Duecker Medizintechnik",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prepare": "pnpm exec husky",
    "clean": "rm -rf .next/ coverage/",
    "clean:nm": "pnpm clean && rm -rf node_modules/"
  },
  "dependencies": {
    "@c15t/nextjs": "^2.0.0",
    "@directus/sdk": "^21.2.2",
    "@directus/visual-editing": "^2.0.0",
    "@hookform/resolvers": "^5.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/nextjs": "^10.49.0",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "express-handlebars": "^9.0.0",
    "flagsmith": "^10.0.0",
    "framer-motion": "^12.38.0",
    "marked": "^18.0.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "nodemailer": "^8.0.5",
    "nodemailer-express-handlebars": "^7.0.0",
    "qs": "^6.15.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-scrollspy-navigation": "^2.0.7",
    "react-share": "^5.3.0",
    "react-spring": "^10.0.3",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/gtag.js": "^0.0.20",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/nodemailer-express-handlebars": "^4.0.6",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-google-recaptcha": "^2.1.9",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "next-router-mock": "^1.0.5",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-debug-screens": "^3.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
  }
}
