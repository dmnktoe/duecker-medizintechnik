{
  "name": "duecker-medizintechnik",
  "version": "1.1.0",
  "private": true,
  "author": "Domenik Toefflinger",
  "description": "Website for Duecker Medizintechnik",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prepare": "husky install",
    "clean": "rm -rf .next/ coverage/",
    "clean:nm": "pnpm clean && rm -rf node_modules/"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@next/bundle-analyzer": "^14.2.24",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@sentry/nextjs": "^8",
    "axios": "^1.8.1",
    "clsx": "^2.1.1",
    "express-handlebars": "^8.0.0",
    "flagsmith": "^4.1.4",
    "framer-motion": "^12.0.0",
    "i18next": "^25.0.0",
    "marked": "^16.0.0",
    "next": "^14.2.24",
    "next-i18next": "^15.4.2",
    "nextjs-progressbar": "^0.0.16",
    "nodemailer": "^6.10.0",
    "nodemailer-express-handlebars": "^6.1.2",
    "qs": "^6.14.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^14.1.3",
    "react-icons": "^5.5.0",
    "react-scrollspy-navigation": "^2.0.6",
    "react-share": "^5.2.2",
    "swiper": "^11.2.4",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2",
    "zustand": "^4.5.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/gtag.js": "^0.0.20",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/qs": "^6.9.18",
    "@types/react": "^18.3.18",
    "@types/react-google-recaptcha": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "axios-mock-adapter": "^2.0.0",
    "cobe": "^0.6.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.24",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "lint-staged": "^16.0.0",
    "next-router-mock": "^1.0.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-spring": "^10.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-debug-screens": "^3.0.0",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
  }
}
