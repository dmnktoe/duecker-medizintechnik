{
  "name": "duecker-medizintechnik",
  "version": "0.1.0",
  "private": true,
  "author": "Domenik Toefflinger",
  "description": "Website for Duecker Medizintechnik",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && yarn format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "prepare": "husky install",
    "clean": "rm -rf .next/ coverage/",
    "clean:nm": "rm -rf node_modules/",
    "lhci:mobile": "lhci autorun",
    "lhci:desktop": "lhci autorun --collect.settings.preset=desktop"
  },
  "dependencies": {
    "@dotlottie/react-player": "^1.6.5",
    "@hookform/resolvers": "^3.3.2",
    "@next/bundle-analyzer": "^14.0.3",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-collapsible": "^1.0.3",
    "axios": "^1.6.1",
    "clsx": "^2.0.0",
    "express-handlebars": "^6.0.7",
    "framer-motion": "^10.16.4",
    "i18next": "^23.5.1",
    "lucide-react": "^0.323.0",
    "marked": "^9.0.3",
    "next": "^14.0.0",
    "next-i18next": "^14.0.3",
    "nextjs-progressbar": "^0.0.16",
    "nodemailer": "^6.9.7",
    "nodemailer-express-handlebars": "^6.1.0",
    "qs": "^6.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-fast-marquee": "^1.6.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.48.2",
    "react-i18next": "^13.2.2",
    "react-icons": "^4.11.0",
    "react-share": "^5.0.0",
    "react-stagger-text": "^1.0.6",
    "sharp": "^0.33.0",
    "swiper": "^10.3.0",
    "tailwind-merge": "^2.0.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@lhci/cli": "^0.13.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.6",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "@types/gtag.js": "^0.0.19",
    "@types/jest": "^29.5.5",
    "@types/nodemailer": "^6.4.14",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/qs": "^6.9.8",
    "@types/react": "^18.2.22",
    "@types/react-google-recaptcha": "^2.1.8",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "autoprefixer": "^10.4.16",
    "axios-mock-adapter": "^1.22.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.0",
    "next-router-mock": "^0.9.10",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.30",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.4",
    "tailwindcss": "^3.3.3",
    "tailwindcss-debug-screens": "^2.2.1",
    "typescript": "^5.2.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "**/*.{json,css,scss,md,webmanifest}": [
      "prettier -w"
    ]
  }
}
