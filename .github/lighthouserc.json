{
  "ci": {
    "collect": {
      "startServerCommand": "yarn build && yarn start",
      "startServerReadyPattern": "ready",
      "startServerReadyTimeout": 80000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/404",
        "http://localhost:3000/allgemeine-geschaeftsbedingungen",
        "http://localhost:3000/datenschutz",
        "http://localhost:3000/downloads",
        "http://localhost:3000/impressum",
        "http://localhost:3000/kontakt",
        "http://localhost:3000/leistungen",
        "http://localhost:3000/leistungen/produktion",
        "http://localhost:3000/leistungen/produktion/produkt-uebersicht",
        "http://localhost:3000/leistungen/reparatur",
        "http://localhost:3000/leistungen/vertrieb",
        "http://localhost:3000/newsroom",
        "http://localhost:3000/unternehmen"
      ],
      "numberOfRuns": 1
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
